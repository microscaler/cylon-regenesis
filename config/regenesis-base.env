# Base image provisioning (Multipass resurrection-node-base).
# Installs Firecracker, guest kernel, cylon binary, systemd units — no hub register.
REGENESIS_PROVISIONING=base
REGENESIS_NODE_ID=resurrection-node-base
REGENESIS_HUB_API=http://192.168.1.189:14000
REGENESIS_RELEASE_PIN=latest
REGENESIS_GITHUB_TOKEN_FILE=/etc/cylon/github-token
REGENESIS_GUEST_KERNEL_IMAGE=ghcr.io/microscaler/cylon-kernel:6.1.102
REGENESIS_FIRECRACKER_VERSION=1.10.1
REGENESIS_CRANE_VERSION=v0.20.2
